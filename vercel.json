{
  "version": 2,
  "name": "refugee-digital-identity",
  "builds": [
    {
      "src": "apps/refugee-digital-identity-pwa/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/$",
      "dest": "/apps/refugee-digital-identity-pwa/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/apps/refugee-digital-identity-pwa/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
